params {
	// Do not simply print pipeline metadata and exit
	version = false

	// Input options
	help = false
	input = false
	metadata = false

	// Processing options
	skip_primer_trim = false
	skip_nb = false
	run_picrust2 = false
	download_db = false
	skip_phylotree = false

	// QC parameters
	filterQ = 20
	downsample = 0

	// DADA2 parameters
	min_len = 1000
	max_len = 1600
	omegac = "1e-40"
	max_ee = 2
	minQ = 0
	learn_error_sample = false
	pooling_method = 'pseudo'
	error_model = 'auto'	// Error model for DADA2 learnErrors: auto, pacbio, binned, loess

	// ASV filtering parameters
	min_asv_totalfreq = 5	// Will be set to 0 for single sample [cite: 2]
	min_asv_sample = 1		// Will be set to 0 for single sample [cite: 3]

	// VSEARCH parameters
	maxreject = 100
	maxaccept = 100
	vsearch_identity = 0.97

	// Primer sequences (V1-V9 adapter by default)
	front_p = 'AGRGTTYGATYMTGGCTCAG'
	adapter_p = 'AAGTCGTAACAAGGTARCY'

	// Resource allocation
	dada2_cpu = 256
	vsearch_cpu = 256
	cutadapt_cpu = 64

	// Database paths
	vsearch_db = "${projectDir}/databases/GTDB_ssu_all_r220.qza"
	vsearch_tax = "${projectDir}/databases/GTDB_ssu_all_r220.taxonomy.qza"
	silva_db = "${projectDir}/databases/silva_nr99_v138.2_toSpecies_trainset.fa.gz"
	gg2_db = "${projectDir}/databases/gg2_2024_09_toSpecies_trainset.fa.gz"
	gtdb_db = "${projectDir}/databases/GTDB_bac120_arc53_ssu_r220_fullTaxo.fa.gz"

	// Database to prioritize, can be GG2, GTDB, or Silva
	db_to_prioritize = "GG2"

	// Script locations
	rmd_vis_biom_script = "${projectDir}/scripts/visualize_biom.Rmd"
	rmd_helper = "${projectDir}/scripts/import_biom.R"
	primer_fasta = "${projectDir}/scripts/16S_primers.fasta"
	dadaCCS_script = "${projectDir}/scripts/run_dada_2023.2.R"
	dadaAssign_script = "${projectDir}/scripts/dada2_assign_tax.R"
	learnError_script = "${projectDir}/scripts/learnError.R"

	// Output options
	outdir = "${launchDir}/results"
	publish_dir_mode = "copy"	// Allows for workdir removal after success
	save_intermediates = false
	colorby = "condition"
	rarefaction_depth = null

	// Container options
	enable_conda = false
	enable_container = false
	cacheDir = "/opt/conda/envs"
}

// env for qiime - Hierarchical variables restored from Baseline
env {
	TMPDIR = './tmp'
	MPLCONFIGDIR = "${TMPDIR}/mplconfigdir"
	NUMBA_CACHE_DIR = "${TMPDIR}/numbacache"
	MAFFT_TMPDIR = "${TMPDIR}/mafft_tmpdir"
}

// Executor configuration
executor {
	// Change to Local and comment-out queue if running locally
	name = 'slurm'
	max_retries = 3
	queue = 'defq'
}

// Default if using Local
process {
	// Default cpu if not specified
	cpus = 32
	// Set tmpdir before every process
	beforeScript = "mkdir -p ${env.TMPDIR}"
}

// CPU and memory configurations - Preserved High-Performance Baseline
process {
	withLabel: cpu_def {
		cpus = 8
		memory = 32.GB
	}

	withLabel: cpu8 {
		cpus = 16
		memory = 64.GB
	}

	withLabel: cpu32 {
		cpus = 64
		memory = 256.GB
	}
}


/**
 * Execution Profiles
 */

// Shared Conda setup
def conda_setup = {
	conda {
		useMamba = false
		enabled = true
		createTimeout = '2 h'
		cacheDir = "${params.cacheDir}"
	}
}

// Resets all container engines to false to ensure no conflicts.
def disable_all_engines = {
	docker.enabled		 = false
	singularity.enabled  = false
	podman.enabled		 = false
	shifter.enabled		 = false
	charliecloud.enabled = false
	singularity.autoMounts = false
}

profiles {
	// Use conda by default
	standard {
		disable_all_engines()
		conda_setup()
		params.enable_conda = true
	}

	conda {
		disable_all_engines()
		conda_setup()
		params.enable_conda = true
	}

	singularity {
		disable_all_engines()
		singularity {
			enabled = true
			autoMounts = true
			command = '/bin/singularity.nosuid-orig'
			cacheDir = "${params.cacheDir}/singularity"
			// Bind Host TMPDIR to container /tmp for DADA2 consistency
			runOptions = "--bind ${env.TMPDIR}:./tmp --bind ${params.cacheDir}:/home/qiime2"
		}
		params.enable_container = true
	}

	docker {
		disable_all_engines()
		docker.enabled = true
		params.enable_container = true
	}
}

// Execution reports
['report', 'timeline', 'dag', 'trace'].each { name ->
	"${name}" {
		enabled = true
		overwrite = true
		file = "${params.outdir}/${name == 'trace' ? 'execution_trace.txt' : name + '.html'}"
	}
}
